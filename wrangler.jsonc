{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "health-care",
  // 今天日期（2026-07-23）
  "compatibility_date": "2026-07-23",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "vars": {
    // 智谱 GLM 模型 id（OpenAI 兼容端点，决策 07）。
    // ZHIPU_API_KEY 走 secret：本地 .dev.vars，生产 `wrangler secret put ZHIPU_API_KEY`（类型见 src/types/env.d.ts）。
    "ZHIPU_MODEL": "glm-4.7"
  },
  "observability": {
    "enabled": true
  },
  // D1 主存储（决策 08）。database_id 为本地占位；
  // 创建远程库（部署阶段）后替换为真实 id。
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "health-care",
      "database_id": "local-dev-placeholder",
      "migrations_dir": "migrations"
    }
  ]
}

{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "health-care",
  // 今天日期（2026-07-23）
  "compatibility_date": "2026-07-23",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "triggers": {
    // 每日 00:00 UTC（上海 08:00）触发 AI 小结自动生成；scheduled 按设置决定是否跑
    "crons": ["0 0 * * *"]
  },
  "vars": {
    // 智谱 GLM 模型 id（OpenAI 兼容端点，决策 07）。
    // ZHIPU_API_KEY 走 secret：本地 .dev.vars，生产 `wrangler secret put ZHIPU_API_KEY`（类型见 src/types/env.d.ts）。
    "ZHIPU_MODEL": "glm-4.7"
  },
  "observability": {
    "enabled": true
  },
  // D1 主存储（决策 08）。database_id 为本地占位；
  // 创建远程库（部署阶段）后替换为真实 id。
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "health-care",
      "database_id": "1a393365-2c0b-43be-98dd-d2767022cd4f",
      "migrations_dir": "migrations"
    }
  ]
}
